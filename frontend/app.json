{
  "expo": {
    "name": "Swastik Hotel",
    "slug": "swastik-hotel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swastikhotel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swastik.hotel",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture Aadhar card photos for guest check-in",
        "NSPhotoLibraryUsageDescription": "Select Aadhar card photos for guest check-in"
      }
    },
    "android": {
      "package": "com.swastik.hotel",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F382E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F382E"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Select Aadhar card photos for guest check-in",
          "cameraPermission": "Capture Aadhar card photos for guest check-in"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
